# ── Backend connection ──────────────────────────
BACKEND_URL=http://localhost:5000/api
BACKEND_EMAIL=admin@example.com
BACKEND_PASSWORD=your_admin_password

# ── Device config — change this ONE value to switch hardware ──
# Options: cpu | cuda | mps (mac)
DEVICE=cpu

# ── Camera source ──────────────────────────────
# 0 = default webcam, or RTSP URL, or video file path
CAMERA_SOURCE=0
CAMERA_ID=CAM-001

# ── Model paths ─────────────────────────────────
YOLO_MODEL=yolov8n.pt        # n=nano(fastest,CPU-friendly) s/m/l/x = bigger+more accurate
FACE_MODEL=ArcFace           # ArcFace | Facenet | Facenet512 | VGG-Face

# ── Detection thresholds ────────────────────────
PERSON_CONF_THRESHOLD=0.5
FACE_MATCH_THRESHOLD=0.6
LOITERING_SECONDS=30
ALERT_COOLDOWN_SECONDS=60

# ── Feature toggles ──────────────────────────────
ENABLE_FACE_RECOGNITION=true
ENABLE_ACTIVITY_CLASSIFIER=true
ENABLE_LOITERING_DETECTION=true
SAVE_SNAPSHOTS=true

# ── Performance ──────────────────────────────────
PROCESS_EVERY_NTH_FRAME=3    # Skip frames to save CPU; raise for slower hardware
DISPLAY_WINDOW=true          # Show OpenCV window (set false for headless/Colab)
